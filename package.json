{
  "name": "@leonezz/noisy-claw",
  "version": "0.1.0",
  "description": "OpenClaw voice channel plugin — bidirectional voice as a first-class channel",
  "type": "module",
  "dependencies": {
    "@sinclair/typebox": "^0.34.48",
    "commander": "^14.0.3",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "openclaw": ">=2026.1.26"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "channel": {
      "id": "voice",
      "label": "Voice",
      "selectionLabel": "Voice (noisy-claw)",
      "docsPath": "/channels/voice",
      "docsLabel": "voice",
      "blurb": "bidirectional voice channel; speak to your agent, hear it respond.",
      "order": 80,
      "quickstartAllowFrom": false
    },
    "install": {
      "npmSpec": "@leonezz/noisy-claw",
      "defaultChoice": "npm"
    }
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.27.0+sha512.72d699da16b1179c14ba9e64dc71c9a40988cbdc65c264cb0e489db7de917f20dcf4d64d8723625f2969ba52d4b7e2a1170682d9ac2a5dcaeaab732b7e16f04a"
}
